{
  "name": "daily-tracker-miniapp",
  "version": "0.0.1",
  "description": "DailyTracker 每日记录小程序",
  "appid": "wx_daily_tracker_dev",
  "versionName": "1.0.0",
  "versionCode": "100",
  "transformPx": false,
  "mp-weixin": {
