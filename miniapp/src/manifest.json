        "desc": "你的位置信息将用于小程序位置相关功能"
      }
    },
    "darkmode": true,
    "themeLocation": "theme.json"
  },
  "h5": {
    "devServer": {
      "port": 5175,
      "proxy": {
        "/api": {
          "target": "http://localhost:8080",
          "changeOrigin": true
        }
      }
    },
    "title": "DailyTracker"
