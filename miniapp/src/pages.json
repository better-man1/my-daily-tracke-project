{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/login/index",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationBarBackgroundColor": "#0f1117",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "今日概览",
        "navigationBarBackgroundColor": "#0f1117",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/plan/index",
      "style": {
        "navigationBarTitleText": "每日计划",
        "navigationBarBackgroundColor": "#0f1117",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/accounting/index",
      "style": {
        "navigationBarTitleText": "每日记账",
        "navigationBarBackgroundColor": "#0f1117",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/excerpt/index",
      "style": {
        "navigationBarTitleText": "每日摘录",
        "navigationBarBackgroundColor": "#0f1117",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/summary/index",
      "style": {
        "navigationBarTitleText": "每日总结",
        "navigationBarBackgroundColor": "#0f1117",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/goal/index",
      "style": {
        "navigationBarTitleText": "目标管理",
        "navigationBarBackgroundColor": "#0f1117",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/profile/index",
      "style": {
        "navigationBarTitleText": "我的",
        "navigationBarBackgroundColor": "#0f1117",
        "navigationBarTextStyle": "white"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "DailyTracker",
    "navigationBarBackgroundColor": "#0f1117",
    "backgroundColor": "#0f1117",
    "backgroundTextStyle": "light",
    "enablePullDownRefresh": false,
    "onReachBottomDistance": 50,
    "app-plus": {
      "background": "#0f1117"
    }
  },
  "tabBar": {
    "color": "#64748b",
    "selectedColor": "#6366f1",
    "backgroundColor": "#13151f",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "static/tabs/home.png",
        "selectedIconPath": "static/tabs/home-active.png"
      },
      {
        "pagePath": "pages/plan/index",
        "text": "计划",
        "iconPath": "static/tabs/plan.png",
        "selectedIconPath": "static/tabs/plan-active.png"
      },
      {
        "pagePath": "pages/accounting/index",
        "text": "记账",
        "iconPath": "static/tabs/accounting.png",
        "selectedIconPath": "static/tabs/accounting-active.png"
      },
      {
        "pagePath": "pages/summary/index",
        "text": "总结",
        "iconPath": "static/tabs/summary.png",
        "selectedIconPath": "static/tabs/summary-active.png"
      },
      {
        "pagePath": "pages/profile/index",
        "text": "我的",
        "iconPath": "static/tabs/profile.png",
        "selectedIconPath": "static/tabs/profile-active.png"
      }
    ]
  },
  "condition": {
    "current": 0,
    "list": [
      {
        "id": 0,
        "name": "首页",
        "pathAndQuery": "pages/index/index"
      }
    ]
  }
}
